# Field Monitor — non-secret config only.
# Local runs: passwords live in macOS Keychain via: python scripts/store_secrets.py
# GitHub Actions: set GMAIL_APP_PASSWORD and RECIPIENT_EMAIL as repo Secrets.

MEDIUM_GOOGLE_EMAIL=hegde86vinay@gmail.com
GMAIL_SMTP_USER=hegde86vinay@gmail.com
RECIPIENT_EMAIL=hegde86vinay@gmail.com

# GitHub Actions Secrets to configure (Settings → Secrets → Actions):
# GMAIL_SMTP_USER      — your Gmail address
# GMAIL_APP_PASSWORD   — 16-char App Password from myaccount.google.com/apppasswords
# RECIPIENT_EMAIL      — where to send the digest
